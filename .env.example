# Spotify App Credentials
# Create an app at https://developer.spotify.com/dashboard
# The client secret must also be configured in Supabase Dashboard under Auth > Providers > Spotify
VITE_SPOTIFY_CLIENT_ID=your_client_id_here

# Supabase Configuration
# Create a project at https://supabase.com/dashboard
# Enable Spotify as an auth provider under Authentication > Providers
# Set the Spotify scopes: user-read-private playlist-read-private playlist-modify-public playlist-modify-private user-library-modify
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Anthropic API Key (server-side only — set via: supabase secrets set ANTHROPIC_API_KEY=sk-...)
# Do NOT set VITE_ANTHROPIC_API_KEY in client env — the key is used by the Edge Function only
