# Spotify App Credentials
# Create an app at https://developer.spotify.com/dashboard
# Set the redirect URI in your Spotify app settings to match the one below
# Note: Spotify requires loopback addresses to use explicit IP (127.0.0.1), not localhost
VITE_SPOTIFY_CLIENT_ID=your_client_id_here
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173

# Anthropic API Key (for listening guide feature)
# Get your API key at https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
